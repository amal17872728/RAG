CHAT_MODEL=<ollama-chat-model>
EMBED_MODEL=<ollama-embedding-model>
OLLAMA_BASE_URL=<ollama-base-url>
QDRANT_COLLECTION=<qdrant-collection-name>
QDRANT_PORT=<host-qdrant-port>
OLLAMA_PORT=<host-ollama-port>
BACKEND_PORT=<host-backend-port>
FRONTEND_PORT=<host-frontend-port>
EMBED_CACHE_DIR=<container-embedding-cache-dir>
CORS_ORIGINS=<comma-separated-browser-origins>
ENABLE_STREAMING=true
ENABLE_CITATION_REPAIR=true
ENABLE_QUERY_REWRITING=true
ENABLE_MULTI_QUERY_RETRIEVAL=true
ENABLE_CONVERSATION_MEMORY=true
ENABLE_SUMMARY_GENERATION=true
ENABLE_BACKGROUND_INGESTION=true
ENABLE_PERF_LOGS=true
ENABLE_CITATION_DEBUG_LOGS=false
ENABLE_MEMORY_DEBUG_LOGS=false
